# Caddyfile — reverse proxy with automatic HTTPS for Kirkalab.
# Caddy obtains and renews Let's Encrypt certificates automatically.
# It serves the static frontend (mounted at /srv) and proxies the API
# and health check to the FastAPI app (uvicorn on port 8000).
# Set the DOMAIN and ACME_EMAIL variables in your prod .env file.

{$DOMAIN} {
	tls {$ACME_EMAIL}

	root * /srv

	# API and health check go to the FastAPI app.
	@backend path /api/* /health
	reverse_proxy @backend app:8000

	# Everything else is the static SPA; fall back to index.html.
	try_files {path} /index.html
	file_server

	# Security headers.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Access + error logs (JSON), rotated by Caddy.
	log {
		output file /var/log/caddy/access.log {
			roll_size 10MiB
			roll_keep 10
			roll_keep_for 720h
		}
		format json
	}
}
