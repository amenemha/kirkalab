# Caddyfile — reverse proxy with automatic HTTPS for the Kirkalab API.
# Caddy obtains and renews Let's Encrypt certificates automatically.
# Set the DOMAIN and ACME_EMAIL variables in your prod .env file.

{$DOMAIN} {
	tls {$ACME_EMAIL}

	# Proxy all traffic to the FastAPI app (uvicorn on port 8000).
	reverse_proxy app:8000

	# Security headers.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Access + error logs (JSON), rotated by Caddy.
	log {
		output file /var/log/caddy/access.log {
			roll_size 10MiB
			roll_keep 10
			roll_keep_for 720h
		}
		format json
	}
}
