# Kirkalab backend environment variables (example)
# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Application ---
APP_NAME=kirkalab
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# --- Database ---
# Example: postgresql+psycopg://user:password@localhost:5432/kirkalab
DATABASE_URL=postgresql+psycopg://CHANGE_ME_USER:CHANGE_ME_PASSWORD@localhost:5432/kirkalab

# --- Redis ---
# Used by the bot for FSM persistence and pinged by the backend readiness probe
# (/health/ready). Inside docker-compose use the service name.
REDIS_URL=redis://redis:6379/0

# --- FX / currency layer (Queue 3) ---
# Local-currency conversion (USD/RUB/KZT/UAH/EUR) over the USDT economics.
# Fiat rates are sourced from CoinGecko (the same public endpoint the market
# layer uses) and cached in Redis with this TTL (seconds), with a durable
# fallback to the latest persisted fx_rates snapshot when the source is down.
# All optional — sane defaults are baked in; override only to tune.
FX_CACHE_TTL_SECONDS=3600
FX_HTTP_TIMEOUT_SECONDS=5.0
FX_HTTP_RETRIES=2

# --- Security / Auth ---
# Generate a strong random value, e.g.: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# --- Server ---
HOST=127.0.0.1
PORT=8000

# --- CORS ---
# Comma-separated list of allowed origins. Leave empty to disallow all
# cross-origin requests (secure default). Example: https://kirkalab.ru
CORS_ORIGINS=https://kirkalab.ru

# --- Telegram QR-login ---
# Public bot username used to build the deep link (https://t.me/<BOT_USERNAME>?start=...).
BOT_USERNAME=roibot_ai_bot
# Shared secret the bot sends as the X-Bot-Secret header when approving a QR
# session. REQUIRED in production. Generate, e.g.: openssl rand -hex 32
BOT_INTERNAL_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET
# How long a QR login session stays valid, in seconds.
QR_SESSION_TTL_SECONDS=120

# --- First-admin bootstrap (optional) ---
# If all three values are set, an admin user is created on startup
# (idempotent: skipped if a user with FIRST_ADMIN_EMAIL already exists).
FIRST_ADMIN_EMAIL=
FIRST_ADMIN_HANDLE=
FIRST_ADMIN_PASSWORD=

# --- Production stack (docker-compose.prod.yml) ---
# These are only used by the production compose file. Put real values in .env.prod.

# Postgres service credentials (compose injects them into the db container)
POSTGRES_USER=kirkalab
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=kirkalab

# Caddy reverse proxy (automatic HTTPS via ACME)
DOMAIN=example.com
ACME_EMAIL=admin@example.com

# Telegram bot (the `bot` service runs long-polling)
BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN
# Public bot username (without @), used by the API/bot for QR deep links.
BOT_USERNAME=roibot_ai_bot
# Shared secret the bot sends as X-Bot-Secret when approving QR sessions.
# MUST equal the API's BOT_INTERNAL_SECRET. Generate: openssl rand -hex 32
BOT_INTERNAL_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET

# Telegram chat id that receives bot operational alerts (optional). Leave empty
# to disable alerting. Anti-spam throttle between same-type alerts, in seconds.
ADMIN_CHAT_ID=
ALERT_THROTTLE_SECONDS=300

# Database backups (deploy/backup.sh): how many days of dumps to keep
BACKUP_KEEP_DAYS=7
