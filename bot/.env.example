# Kirkalab Telegram bot environment (example)
# Copy to .env and fill in real values. Never commit the real .env.

# --- Telegram ---
# Token from @BotFather.
BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN

# Public bot username (without @). Used by the API to build QR deep links.
BOT_USERNAME=roibot_ai_bot

# Shared secret sent as the X-Bot-Secret header when the bot approves a QR
# login session. MUST equal the API's BOT_INTERNAL_SECRET, otherwise QR
# approval fails with 403.
BOT_INTERNAL_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET

# --- API ---
# Base URL of the Kirkalab API.
# Inside docker-compose use the service name, e.g. http://app:8000
# For local runs against a host server use http://localhost:8000
API_BASE_URL=http://app:8000

# Request timeout for API calls, seconds.
REQUEST_TIMEOUT=10

# --- Redis (FSM persistence) ---
# Connection string for the Redis used as aiogram FSM storage. Inside
# docker-compose use the service name. Persists user flows across restarts.
REDIS_URL=redis://redis:6379/0

# --- Operational alerts (optional) ---
# Telegram chat id that receives operational alerts (unhandled exceptions,
# backend failures). Leave empty to disable alerting entirely. Get it from
# @userinfobot (personal chat) or use the group/channel id (often negative).
ADMIN_CHAT_ID=
# Minimum seconds between repeated alerts of the same type (anti-spam throttle).
ALERT_THROTTLE_SECONDS=300
